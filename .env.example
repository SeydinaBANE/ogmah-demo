# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...
# Model to use via OpenRouter (any model available on openrouter.ai)
# Examples: anthropic/claude-3.5-sonnet, openai/gpt-4o, mistralai/mistral-large
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Database
DATABASE_URL=postgresql://ogmah:ogmah_secret@localhost:5432/ogmah_db
POSTGRES_USER=ogmah
POSTGRES_PASSWORD=ogmah_secret
POSTGRES_DB=ogmah_db

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated origins allowed for CORS (add your frontend URL in production)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend
VITE_API_BASE_URL=http://localhost:8000
